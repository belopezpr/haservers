global
    log stdout format raw local0

defaults
    log     global
    mode    http
    timeout connect 5s
    timeout client  50s
    timeout server  50s

frontend http_front
    bind *:8080
    default_backend nginx_pool

backend nginx_pool
    balance roundrobin
    server node01 192.168.122.41:80 check
    server node02 192.168.122.42:80 check
    server node03 192.168.122.43:80 check